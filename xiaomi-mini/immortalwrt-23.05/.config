# ===== Xiaomi MiWiFi Mini / MT7620 =====
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7620=y
CONFIG_TARGET_ramips_mt7620_DEVICE_xiaomi_miwifi-mini=y

# ===== WiFi 驱动 =====
CONFIG_PACKAGE_kmod-mt76-core=y
CONFIG_PACKAGE_kmod-mt76x2=y
CONFIG_PACKAGE_kmod-mt76x02-common=y
CONFIG_PACKAGE_kmod-mt76x2-common=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# ===== LuCI 基础 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ===== 基础网络 =====
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

# ===== 实用工具 =====
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ===== 系统优化 =====
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_lsblk=y

# ===== 可选保留 =====
CONFIG_PACKAGE_zlib=y

################################################################

### Frp客户端内网穿透插件
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-i18n-frpc-zh-cn=y
### 内网穿透插件
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
# shadowsocks服务器端插件
CONFIG_PACKAGE_luci-i18n-shadowsocks-libev-zh-cn =y
CONFIG_PACKAGE_shadowsocks-libev-ss-server=y
CONFIG_PACKAGE_shadowsocks-libev-config=y
CONFIG_PACKAGE_luci-app-shadowsocks-libev=y
# shadowsocks-libev-ss-rules=y
# shadowsocks-libev-ss-local=y
# shadowsocks-libev-ss-tunnel=y
###
